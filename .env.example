PORT=3001
NODE_ENV=development
LOG_LEVEL=info

CORS_ORIGIN=http://localhost:3000

# Supabase: pooled for the running API (Prisma adapter)
DATABASE_URL=

# Supabase: direct host for `prisma migrate` / Studio (use URI from Dashboard → Database → Connection string → Direct, if migrate issues persist)
DIRECT_URL=

# Public URL of THIS API (newsletter confirm/unsubscribe links)
APP_PUBLIC_URL=http://localhost:3001

# --- Supabase API (Settings → API) ---
# Project URL (not secret)
SUPABASE_URL=

# service_role key — required for admin user delete + Storage signed uploads. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# JWT secret — Settings → API → JWT Secret (verify access tokens)
SUPABASE_JWT_SECRET=

SUPABASE_STORAGE_BUCKET=

# --- Email (Resend) — optional until you send newsletter mail ---
RESEND_API_KEY=
EMAIL_FROM=

# Expose /api/v1/docs when NODE_ENV=production (ignored in dev)
DOCS_ENABLED=false
