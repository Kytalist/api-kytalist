PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# --- Local-first defaults ---
# These values match `npx supabase start` (Postgres on 54322, API on 54321). They are the public
# Supabase local demo keys — fine to commit and share only for **local** stacks. For cloud Supabase
# or managed Postgres, replace DATABASE_URL, DIRECT_URL, and the SUPABASE_* keys with values from
# your project dashboard (see README).

DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:54322/postgres"
DIRECT_URL="postgresql://postgres:postgres@127.0.0.1:54322/postgres"

# Comma-separated allowed browser origins (set in production). Unset = reflective CORS in dev.
CORS_ORIGIN=

# Public URL for confirm/unsubscribe links in emails.
APP_PUBLIC_URL=http://localhost:3001

# Supabase (local CLI defaults — must match a running `supabase start` on this machine)
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU
SUPABASE_JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long
SUPABASE_STORAGE_BUCKET=listing-images

# Email (Resend). Leave unset for local dev — outbound email is skipped and a warning is logged.
RESEND_API_KEY=
EMAIL_FROM=

# API docs at /api/v1/docs — enable locally; set false or omit in production.
DOCS_ENABLED=true

# Optional local overrides without editing this file: copy `.env.local.example` → `.env.local`
# (`.env.local` is gitignored; duplicate keys there override the above).
