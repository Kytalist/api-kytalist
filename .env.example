PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# Runtime queries (pooled), e.g. Supabase session pooler — use local URL for dev, prod URL in production.
DATABASE_URL=

# Direct connection for Prisma migrations (prisma.config.ts). Local and production use different values.
DIRECT_URL=

# Comma-separated allowed browser origins (set in production). Example: https://kytalist.com,https://www.kytalist.com
CORS_ORIGIN=

# Public URL for confirm/unsubscribe links in emails.
APP_PUBLIC_URL=http://localhost:3001

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
SUPABASE_STORAGE_BUCKET=listing-images

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM=

# Set to "true" to expose /api/v1/docs in production. Defaults to false.
DOCS_ENABLED=false
